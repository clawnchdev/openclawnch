# OpenClawnch — Minimum required config
# Copy to .env and fill in your values, or run: openclawnch init
#
# Full reference with all optional keys: deploy/.env.example

# ── LLM Provider (at least one required) ─────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...
# OPENAI_API_KEY=sk-...
# BANKR_LLM_KEY=...

# ── Channel (at least one required) ──────────────────────────────────────
# TELEGRAM_BOT_TOKEN=123456:ABC...
# DISCORD_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...

# ── Wallet (optional — can configure in chat) ────────────────────────────
# WALLETCONNECT_PROJECT_ID=...
