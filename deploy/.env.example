# OpenClawnch Environment Variables
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.

# ── Required (at least one LLM key) ─────────────────────────────────────

# Anthropic API key (recommended — starts with sk-ant-)
# ANTHROPIC_API_KEY=sk-ant-...

# OR Bankr LLM Gateway key (pay with crypto)
# BANKR_LLM_KEY=

# OR OpenRouter API key (multi-model)
# OPENROUTER_API_KEY=

# OR OpenAI API key (direct)
# OPENAI_API_KEY=

# LLM provider: anthropic | bankr | openrouter | openai (default: anthropic)
# OPENCLAWNCH_LLM_PROVIDER=anthropic

# ── Channel: Telegram ────────────────────────────────────────────────────

# Telegram bot token from @BotFather (format: 123456:ABC-DEF...)
# TELEGRAM_BOT_TOKEN=

# Webhook secret (auto-generated if not set)
# OPENCLAW_TG_WEBHOOK_SECRET=

# ── Channel: Discord ─────────────────────────────────────────────────────

# Discord bot token from https://discord.com/developers/applications
# DISCORD_TOKEN=

# ── Channel: Slack ───────────────────────────────────────────────────────

# Slack bot token
# SLACK_BOT_TOKEN=

# ── Wallet: WalletConnect ────────────────────────────────────────────────

# WalletConnect project ID from https://cloud.reown.com (32 hex chars)
# WALLETCONNECT_PROJECT_ID=

# ── Wallet: Bankr (custodial, multi-chain) ───────────────────────────────

# Bankr Agent API key from https://bankr.bot/api
# BANKR_API_KEY=

# ── Wallet: Private Key (auto-sign mode — USE WITH CAUTION) ─────────────

# Only set this if you want auto-sign mode with a hot wallet.
# CLAWNCHER_PRIVATE_KEY=
# ALLOW_PRIVATE_KEY_MODE=true

# ── Network & RPC ────────────────────────────────────────────────────────

# Custom RPC URL (defaults to public endpoints)
# CLAWNCHER_RPC_URL=

# Alchemy API key (higher-tier RPC access)
# ALCHEMY_API_KEY=

# Network: mainnet | sepolia (default: mainnet)
# CLAWNCHER_NETWORK=mainnet

# ── Clawnch Platform API ─────────────────────────────────────────────────

# Override Clawnch API base URL (default: https://clawn.ch)
# CLAWNCHER_API_URL=

# Clawnch API key (for launch, fees, info)
# CLAWNCHER_API_KEY=

# ── Block Explorers ──────────────────────────────────────────────────────

# Basescan API key (for block_explorer tool on Base)
# BASESCAN_API_KEY=

# Etherscan API key (for block_explorer on Ethereum)
# ETHERSCAN_API_KEY=

# ── DEX & Bridge APIs ───────────────────────────────────────────────────

# 0x API key (DEX aggregator)
# ZEROX_API_KEY=

# 1inch API key (DEX aggregator)
# ONEINCH_API_KEY=

# LI.FI bridge API key
# LIFI_API_KEY=

# ── Price Feeds ──────────────────────────────────────────────────────────

# CoinGecko API key (optional premium tier)
# COINGECKO_API_KEY=

# CoinMarketCap API key
# CMC_API_KEY=

# Birdeye API key (Solana prices)
# BIRDEYE_API_KEY=

# ── X/Twitter (ClawnX) ──────────────────────────────────────────────────

# X API v2 credentials (all 4 required for ClawnX tool)
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=
# X_BEARER_TOKEN=

# ── Integration Services ─────────────────────────────────────────────────

# Herd Intelligence token
# HERD_ACCESS_TOKEN=

# Hummingbot API URL
# HUMMINGBOT_API_URL=

# Molten agent-to-agent matching
# MOLTEN_API_KEY=

# Wayfinder route optimization API key
# WAYFINDER_API_KEY=

# ── Farcaster (Neynar) ───────────────────────────────────────────────────

# Neynar API key (https://neynar.com — required for farcaster tool)
# NEYNAR_API_KEY=

# Neynar signer UUID (required for casting / write operations)
# NEYNAR_SIGNER_UUID=

# Neynar FID (your Farcaster user ID)
# NEYNAR_FID=

# ── Fiat On/Off Ramp ────────────────────────────────────────────────────

# Bridge.xyz API key (https://bridge.xyz — required for fiat_payment tool)
# BRIDGE_API_KEY=

# MoonPay API key (alternative fiat provider)
# MOONPAY_API_KEY=

# Default fiat currency (default: USD)
# FIAT_CURRENCY=USD

# ── NFT ──────────────────────────────────────────────────────────────────

# Reservoir API key (https://reservoir.tools — for NFT data)
# RESERVOIR_API_KEY=

# ── RPC ──────────────────────────────────────────────────────────────────

# Custom RPC URL (overrides default public RPCs)
# RPC_URL=

# QuickNode RPC endpoint
# QUICKNODE_ENDPOINT=

# ── Fly.io (only needed for Fly deployments) ────────────────────────────

# Fly API token for runtime control (/flykeys, /flyrestart, etc.)
# FLY_API_TOKEN=
# FLY_APP_NAME=

# ── Gateway ──────────────────────────────────────────────────────────────

# Port for the OpenClaw gateway (default: 18789)
# GATEWAY_PORT=18789

# ── Webhooks ─────────────────────────────────────────────────────────────

# Webhook ingestion server (default: port 18790, host 0.0.0.0)
# OPENCLAWNCH_WEBHOOK_PORT=18790
# OPENCLAWNCH_WEBHOOK_HOST=0.0.0.0

# ── HTTP Security ────────────────────────────────────────────────────────

# Endpoint allowlist mode (strict = block unlisted, warn = log only)
# OPENCLAWNCH_ALLOWLIST_MODE=strict

# Additional allowed hosts (comma-separated, added to built-in allowlist)
# OPENCLAWNCH_ALLOWED_HOSTS=myapi.example.com,internal.corp.net

# ── State Persistence (auto-set in Docker/Fly, override for local dev) ──

# Directory for transaction history, onboarding state, plans
# OPENCLAWNCH_TX_DIR=

# ── Alerts ───────────────────────────────────────────────────────────────

# Chat ID for owner alerts (credit warnings, errors)
# OPENCLAWNCH_OWNER_CHAT_ID=
